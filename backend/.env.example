PORT=5000
CLIENT_ORIGIN=http://localhost:5173,https://your-frontend.vercel.app

# Atlas URI example (URL-encode special characters in password, e.g. @ -> %40)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/architecture_firm?retryWrites=true&w=majority&appName=architecture-db

JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=7d

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_password
ADMIN_PASSWORD_HASH=

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=architecture_firm/projects

SMTP_SERVICE=gmail
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

ENABLE_CC=false
ENABLE_BCC=false
FAIL_SAFE_EMAIL=your_email@gmail.com